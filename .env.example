# ─────────────────────────────────────────────────────────────────────────────
# .env de PRODUCTION (VPS / Docker). Copier en `.env` à côté du docker-compose.yml.
# Lu par docker compose à la fois pour :
#   - l'interpolation des build args NEXT_PUBLIC_* (variables inlinées au build)
#   - l'injection runtime (env_file) des secrets serveur.
# NE JAMAIS committer le .env rempli (secrets).
# ─────────────────────────────────────────────────────────────────────────────

# Lien « Trading » → sous-domaine de l'app Klartè Trade (nouvel onglet).
NEXT_PUBLIC_TRADE_URL=https://trade.klarte.re

# Supabase (partagé avec l'app mobile).
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# URL publique de l'app vie-web.
NEXT_PUBLIC_SITE_URL=https://vie.klarte.re

# Clé API Claude — serveur uniquement (route /api/recipes/format, Lot 3).
ANTHROPIC_API_KEY=sk-ant-...
