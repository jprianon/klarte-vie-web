# ─────────────────────────────────────────────────────────────────────────────
# .env de PRODUCTION (VPS / Docker). Copier en `.env` à côté du docker-compose.yml.
# Lu par docker compose à la fois pour :
#   - l'interpolation des build args NEXT_PUBLIC_* (variables inlinées au build)
#   - l'injection runtime (env_file) des secrets serveur.
# NE JAMAIS committer le .env rempli (secrets).
# ─────────────────────────────────────────────────────────────────────────────

# Lien « Trading » → sous-domaine de l'app Klartè Trade (nouvel onglet).
NEXT_PUBLIC_TRADE_URL=https://trade.klarte.re

# URL publique de l'app vie-web.
NEXT_PUBLIC_SITE_URL=https://vie.klarte.re

# ─── Accès partagé (sans comptes) ───────────────────────────────────────────
# UN seul code commun protège toute l'app (toi + ta copine, mêmes données).
# Laisser VIDE = aucune protection (app ouverte à qui connaît l'URL).
# Variable runtime : la changer + recréer le conteneur suffit (pas de rebuild).
ACCESS_CODE=

# ─── Base de données des recettes (Postgres auto-hébergé, conteneur "db") ────
# POSTGRES_PASSWORD : choisis un mot de passe (utilisé par le conteneur db).
# DATABASE_URL : doit contenir le MÊME mot de passe. L'app lit uniquement cette
# variable pour se connecter (host = "db", le nom du service Docker).
POSTGRES_PASSWORD=change-moi-un-mot-de-passe-solide
DATABASE_URL=postgres://klarte:change-moi-un-mot-de-passe-solide@db:5432/klarte

# Supabase — OPTIONNEL (plus utilisé par les recettes). Laisser vide si non
# utilisé ; ne sert qu'à un éventuel branchement auth futur.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Reformatage IA des recettes (route /api/recipes/format) ────────────────
# Moteur : "claude" (API, payant) ou "ollama" (LLM local sur le VPS, gratuit).
# Non défini → Claude si ANTHROPIC_API_KEY présent, sinon reformatage désactivé
# (l'UI bascule alors en saisie manuelle).
RECIPE_AI_PROVIDER=claude

# Clé API Claude — utilisée si RECIPE_AI_PROVIDER=claude (serveur uniquement).
ANTHROPIC_API_KEY=sk-ant-...

# Ollama — utilisé si RECIPE_AI_PROVIDER=ollama. Service Docker local (profil
# "ollama"), joignable sur le réseau interne. Modèle 3B recommandé (VPS sans GPU).
OLLAMA_URL=http://ollama:11434
RECIPE_AI_MODEL=qwen2.5:3b
