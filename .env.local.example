# --- Supabase (partagé avec l'app mobile klarte-vie) ---
# Project Settings > API dans le dashboard Supabase.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Utilisé uniquement par la CLI `pnpm db:types` (jamais exposé au client).
SUPABASE_PROJECT_ID=xxxxxxxxxxxx

# URL publique de l'app (redirections auth).
NEXT_PUBLIC_SITE_URL=http://localhost:3031

# --- Klartè Trade (app séparée, ouverte dans un nouvel onglet au clic « Trading ») ---
# En dev, le serveur/conteneur trade tourne sur le port 3002.
NEXT_PUBLIC_TRADE_URL=http://localhost:3002

# --- IA (Lot 3 : reformatage note -> recette) ---
# Clé API Claude, utilisée UNIQUEMENT côté serveur (route /api/recipes/format).
ANTHROPIC_API_KEY=sk-ant-...
