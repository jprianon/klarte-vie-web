# Copie les paquets au lieu de les hardlinker depuis le store pnpm.
# INDISPENSABLE ici : le workspace est sur OneDrive, dont le pilote Files-On-Demand
# convertit les hardlinks en placeholders cassés → fichiers « Cannot find module »
# au build, même OneDrive.exe arrêté. Copier des vrais fichiers évite ce piège.
package-import-method=copy

# Remonte les dépendances d'ESLint au niveau racine de node_modules.
# Contourne un bug de résolution pnpm avec eslint-config-next (es-errors introuvable).
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*es-errors*
public-hoist-pattern[]=*get-intrinsic*
